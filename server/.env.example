# --------------------------------------------------------------------------
# Authentication: DefaultAzureCredential is used by default (managed identity
# in Azure, Azure CLI / VS Code locally).  API keys below are optional
# fallbacks — set them only if DefaultAzureCredential is unavailable.
# --------------------------------------------------------------------------

# Azure Cosmos DB
COSMOS_ENDPOINT=
COSMOS_KEY=                        # optional — omit to use DefaultAzureCredential
COSMOS_DATABASE=ot-tag-registry

# Azure AI Search
SEARCH_ENDPOINT=
SEARCH_API_KEY=                    # optional — omit to use DefaultAzureCredential
SEARCH_INDEX_NAME=golden-tags

# Azure OpenAI
OPENAI_ENDPOINT=
OPENAI_API_KEY=                    # optional — omit to use DefaultAzureCredential
OPENAI_EMBEDDING_DEPLOYMENT=
