# --------------- Azure AI Search + embeddings ---------------
SEARCH_ENDPOINT=
SEARCH_INDEX_NAME=golden-tags
PROJECT_EMBEDDING_DEPLOYMENT=

# --------------- AI chat completion (auto-fill) ---------------
PROJECT_CHAT_DEPLOYMENT=

# --------------- Function App (auto-fill tools) ---------------
FUNCTION_APP_URL=
